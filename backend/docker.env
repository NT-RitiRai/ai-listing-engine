# backend/docker.env
# This file contains Docker-specific environment variables

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_listing

# Redis
REDIS_URL=redis://:redis_password@redis:6379/0

# API Keys (set in production .env)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Security
SECRET_KEY=your-secret-key-here

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost,http://frontend

# Application
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# Uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=104857600

# Logging
LOG_DIR=/app/logs
